# Meridian AI — environment variables (placeholders only; never commit real secrets).
#
# Copy this file to .env.local and fill in real values. The app degrades
# gracefully when any single provider key is missing — the resolver records
# a skip reason in ContactResolution.detail / skippedSources instead of
# crashing.

# ── REQUIRED ──────────────────────────────────────────────────────────
# Claude / Anthropic — powers AI features (call scripts, assistant, etc.).
# When unavailable the product falls back to deterministic templates for
# everything except generate_opportunity_summary. See
# docs/KNOWN_LIMITATIONS.md for what degrades.
ANTHROPIC_API_KEY=

# Session signing secret for the UI auth cookie. Any random string works
# in dev; rotate for prod.
SESSION_SECRET=

# ── OPTIONAL: MCP auth for external callers ───────────────────────────
# When set, /api/mcp accepts `x-mcp-key: <value>` header auth in addition
# to the session cookie. Leave blank to force UI/session auth only.
MCP_SECRET=

# ── OPTIONAL: Contact resolver providers ──────────────────────────────
# Add whichever you have. Each adapter runs in parallel and returns [] on
# missing key. Precedence documented in docs/SOURCE_PRIORITY.md.

# Google Places — highest-priority verified phones. GOOGLE_API_KEY is the
# canonical name; GOOGLE_PLACES_API_KEY is a legacy alias (both accepted).
# Needs Places API (New or Legacy) enabled on the Cloud project.
GOOGLE_API_KEY=

# Yelp Fusion — secondary verified phones. https://www.yelp.com/developers
YELP_API_KEY=

# Hunter.io Domain Search — observed emails with provider confidence.
# Never guesses. https://hunter.io/api-keys
HUNTER_API_KEY=

# BBB is not a public API — this points at an internal proxy. Expected
# response shape in lib/contacts/sources/bbb.ts. Leave blank to skip.
BBB_SEARCH_URL=

# Facebook Graph no longer exposes page search — self-hosted proxy only.
# Shape in lib/contacts/sources/facebook.ts. Leave blank to skip.
FACEBOOK_SEARCH_URL=

# ── FUTURE PROVIDERS (not wired yet — see docs/KNOWN_LIMITATIONS.md) ──
# Slots reserved so adding an adapter later is env-only work, no branch
# needs a config schema change. Uncomment and wire when needed.
# APOLLO_API_KEY=
# PDL_API_KEY=
# PAGESPEED_API_KEY=
